# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — path is relative to the working directory /app)
DATABASE_URL=sqlite:data/blog.db

# PostgreSQL example (swap sqlx feature to "postgres" in Cargo.toml to use)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=supersecretkey123

# How long access tokens stay valid (hours). Default: 24
ACCESS_JWT_EXP_HOURS=24

# How long refresh tokens stay valid (hours). Default: 360  (~15 days)
REFRESH_JWT_EXP_HOURS=360

# ── Media Storage ─────────────────────────────────────────────────────────────
# Directory where uploaded files are stored.
# On Fly.io this must live inside the mounted volume (/app/data/...)
MEDIA_PATH=./media

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin allowed to call the /mail/contact-form endpoint.
# Defaults to https://portfolio.huuthangle.site if not set.
ALLOWED_ORIGIN=https://portfolio.huuthangle.site

# ── Email / SMTP (lettre) ─────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=you@example.com
# SMTP_TO=you@example.com
