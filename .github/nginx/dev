server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dev.huuthang.site;

    # SSL configuration managed by Certbot
    ssl_certificate /etc/letsencrypt/live/dev.huuthang.site/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dev.huuthang.site/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        # This is the magic part: forward the request to Apache
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# The HTTP to HTTPS redirect block remains the same
server {
    listen 80;
    listen [::]:80;
    server_name dev.huuthang.site;
    return 301 https://$host$request_uri;
}